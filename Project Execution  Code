def download_dataset():
    """Download CIFAR-100 dataset"""
    print_section("Dataset Download", "📥")

    try:
        import torch
        import torchvision
        import torchvision.transforms as transforms

        print_info("Downloading CIFAR-100 dataset...")

        # Create data directory
        data_dir = './data'
        os.makedirs(data_dir, exist_ok=True)

        # Download CIFAR-100
        transform = transforms.Compose([
            transforms.ToTensor(),
            transforms.Normalize((0.5071, 0.4867, 0.4408),
                                (0.2675, 0.2565, 0.2761))
        ])

        trainset = torchvision.datasets.CIFAR100(
            root=data_dir, train=True,
            download=True, transform=transform
        )

        testset = torchvision.datasets.CIFAR100(
            root=data_dir, train=False,
            download=True, transform=transform
        )

        print_success(f"Dataset downloaded successfully!")
        print_info(f"Training samples: {len(trainset)}")
        print_info(f"Test samples: {len(testset)}")
        print_info(f"Classes: {len(trainset.classes)}")

        # Show sample images
        print_info("Sample images from CIFAR-100:")
        fig, axes = plt.subplots(2, 5, figsize=(15, 6))
        for i in range(10):
            img, label = trainset[i]
            ax = axes[i//5, i%5]
            ax.imshow(np.transpose(img.numpy(), (1, 2, 0)))
            ax.set_title(f"Class: {trainset.classes[label]}")
            ax.axis('off')
        plt.tight_layout()
        plt.show()

        return trainset, testset

    except Exception as e:
        print_error(f"Error downloading dataset: {e}")
        return None, None

def setup_environment():
    """Setup the Colab environment"""
    print_section("Environment Setup", "⚙️")

    # Check if running in Colab
    try:
        import google.colab
        IN_COLAB = True
        print_success("Running in Google Colab")
    except:
        IN_COLAB = False
